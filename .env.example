# --- RABBITMQ (для всех сервисов) ---
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=your_username
RABBIT_PASSWORD=your_pass

RABBIT_WAIT_TIME=10s
RABBIT_ATTEMPTS=5

ACCOUNT_EXCHANGE=account_topic
ACCOUNT_ROUTING_KEY=account.created

USER_SERVICE_QUEUE=account_create

# --- AUTH SERVICE ---
AUTH_PG_HOST=localhost
AUTH_PG_PORT=5432
AUTH_PG_USER=your_username
AUTH_PG_PASSWORD=your_pass
AUTH_PG_NAME=your_db
AUTH_PG_SSL_MODE=prefer

AUTH_PG_OPEN_CONNECTIONS=25
AUTH_PG_IDLE_CONNECTIONS=25
AUTH_PG_CONNECTION_LIFETIME=5m

AUTH_ACCESS_SECRET=your_access_secret_key
AUTH_REFRESH_SECRET=your_refresh_secret_key
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h

AUTH_PASSWORD_COST=4

AUTH_GRPC_PORT=50051
AUTH_LOG_LEVEL=INFO
AUTH_ENVIRONMENT=test

# --- USER SERVICE ---
USER_DB_HOST=localhost
USER_DB_PORT=5432
USER_DB_USER=your_username
USER_DB_PASSWORD=your_pass
USER_DB_NAME=your_db
USER_DB_SSL_MODE=prefer

USER_DB_OPEN_CONNECTIONS=25
USER_DB_IDLE_CONNECTIONS=25
USER_DB_CONNECTION_LIFETIME=5m

USER_GRPC_PORT=50052
USER_LOG_LEVEL=INFO
USER_ENVIRONMENT=test

# --- AD SERVICE ---
AD_PG_HOST=localhost
AD_PG_PORT=5433
AD_PG_USER=your_username
AD_PG_PASSWORD=your_pass
AD_PG_DB_NAME=your_db
AD_PG_SSL_MODE=prefer

AD_PG_OPEN_CONNECTIONS=25
AD_PG_IDLE_CONNECTIONS=25
AD_PG_CONNECTION_LIFETIME=5m

AD_MONGO_HOST=localhost
AD_MONGO_PORT=27017
AD_MONGO_USER=your_username
AD_MONGO_PASSWORD=your_pass
AD_MONGO_DB_NAME=your_db

AD_MONGO_COLLECTION_NAME=ads

AD_GRPC_PORT=50053
AD_LOG_LEVEL=INFO
AD_ENVIRONMENT=test

# --- GraphQL Gateway ---
AUTH_GRPC_ADDR=localhost:50051
USER_GRPC_ADDR=localhost:50052
AD_GRPC_ADDR=localhost:50053
GATEWAY_PORT=8080