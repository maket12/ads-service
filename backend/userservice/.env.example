# --- USER SERVICE CONFIG ---
GRPC_PORT=50052
LOG_LEVEL=INFO
ENVIRONMENT=production

# --- RABBITMQ ---
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest

RABBIT_WAIT_TIME=10s
RABBIT_ATTEMPTS=5

ACCOUNT_EXCHANGE=account_topic
ACCOUNT_ROUTING_KEY=account.created

USER_QUEUE=account_create

# --- DATABASE ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=user_pass
DB_NAME=user_db
DB_SSL_MODE=prefer

DB_MAX_CONNECTIONS=30
DB_MIN_CONNECTIONS=10
DB_MAX_CONNECTION_LIFETIME=10m
DB_MAX_CONNECTION_IDLETIME=5m
