# --- AUTH SERVICE CONFIG ---
GRPC_PORT=50051
LOG_LEVEL=INFO
ENVIRONMENT=production

# --- RABBITMQ ---
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASSWORD=guest

RABBIT_WAIT_TIME=10s
RABBIT_ATTEMPTS=5

ACCOUNT_EXCHANGE=account_topic
ACCOUNT_ROUTING_KEY=account.created

# --- DATABASE ---
DB_HOST=localhost
DB_PORT=5431
DB_USER=auth_user
DB_PASSWORD=auth_pass
DB_NAME=auth_db
DB_SSL_MODE=prefer

DB_MAX_CONNECTIONS=30
DB_MIN_CONNECTIONS=10
DB_MAX_CONNECTION_LIFETIME=10m
DB_MAX_CONNECTION_IDLETIME=5m

# --- REDIS ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=auth-redis-password
REDIS_DB_NUM=0

REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONN=2

REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# --- JWT SECURITY ---
ACCESS_SECRET=secret_access_key
REFRESH_SECRET=super_secret_refresh_key
ACCESS_TTL=15m
REFRESH_TTL=720h

# --- PASSWORD HASHER ---
PASSWORD_COST=4

# --- SMTP CLIENT CONFIG ---
SMTP_HOST=example.mail.com
SMTP_PORT=587
SMTP_EMAIL=test@example.com
SMTP_PASSWORD=password

VERIFICATION_BASE_URL=localhost:80/auth/verify
VERIFICATION_TTL=5m
