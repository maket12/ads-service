# --- AUTH SERVICE ---
ENVIRONMENT=development
LOG_LEVEL=INFO
GRPC_PORT=50051

# --- DATABASE ---
PG_HOST=localhost
PG_PORT=5431
PG_USER=auth_user
PG_PASSWORD=auth_pass
PG_DB_NAME=auth_db
PG_SSL_MODE=prefer

PG_OPEN_CONNECTIONS=25
PG_IDLE_CONNECTIONS=25
PG_CONNECTION_LIFETIME=5m

# --- SECURITY ---
ACCESS_SECRET=secret_access_key
REFRESH_SECRET=super_secret_refresh_key
ACCESS_TTL=15m
REFRESH_TTL=720h

PASSWORD_COST=4
